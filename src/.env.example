# Idaho Federated AI Swarm — Environment Configuration
# Copy to .env and adjust as needed.
#
# All ports are offset to avoid collisions with other projects:
#   PostgreSQL 5434, Neo4j 7688/7475, Qdrant 6335, Redis 6381

# ============================================================================
# ENVIRONMENT & DEBUG
# ============================================================================
ENVIRONMENT=development
DEBUG=false
API_VERSION=v1

# ============================================================================
# PostgreSQL Configuration (port 5434)
# ============================================================================
PG_HOST=localhost
PG_PORT=5434
PG_USER=fed_swarm
PG_PASSWORD=fed_swarm_2026

PG_IDHW_DATABASE=fed_idhw
PG_IDJC_DATABASE=fed_idjc
PG_IDOC_DATABASE=fed_idoc

PG_POOL_SIZE=20
PG_MAX_OVERFLOW=10
PG_POOL_TIMEOUT=30
PG_POOL_RECYCLE=3600

# ============================================================================
# Neo4j Configuration (bolt 7688, browser 7475)
# ============================================================================
NEO4J_BOLT_URI=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=fed_swarm_2026
NEO4J_MAX_POOL_SIZE=50

# ============================================================================
# Qdrant Configuration (port 6335)
# ============================================================================
QDRANT_HOST=localhost
QDRANT_PORT=6335
QDRANT_TIMEOUT=30
QDRANT_PREFER_GRPC=false

# ============================================================================
# Redis Configuration (port 6381)
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6381
REDIS_DB=0
# REDIS_PASSWORD=            # No auth by default
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_KEEPALIVE=true

# ============================================================================
# Ollama Configuration (standalone on host)
# ============================================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_EMBEDDING_DIM=768
OLLAMA_TEMPERATURE=0.7
OLLAMA_TOP_P=0.9
OLLAMA_TIMEOUT=300

# ============================================================================
# MCP Endpoint Configuration
# ============================================================================
MCP_IDHW_HOST=localhost
MCP_IDHW_PORT=8001

MCP_IDJC_HOST=localhost
MCP_IDJC_PORT=8002

MCP_IDOC_HOST=localhost
MCP_IDOC_PORT=8003

MCP_TIMEOUT=30

# ============================================================================
# Logging Configuration
# ============================================================================
LOGGING_LEVEL=INFO
LOGGING_FORMAT=json
# LOGGING_FILE=/var/log/fed_swarm/app.log
LOGGING_ROTATION_SIZE=100 MB
LOGGING_RETENTION=7 days
LOGGING_USE_CORRELATION_IDS=true
